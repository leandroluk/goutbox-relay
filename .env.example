# .env.example
#
# Copy this file to .env and adjust the values for your local environment.
#
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env (Windows)
#
# Two sets of variables are used to separate concerns:
#
#   TEST_POSTGRES_URL / TEST_REDIS_URL
#     Used by unit tests (make test-unit, make coverage).
#     These run against real instances but are not the e2e suite.
#     Run `make deps` to start them via docker compose.
#
#   POSTGRES_URL / REDIS_URL
#     Used by the relay binary itself and by the e2e suite (make test-e2e).
#     On Linux/macOS the e2e suite starts its own containers automatically.
#     On Windows, run `make deps` and set these vars.

TEST_POSTGRES_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable
TEST_REDIS_URL=redis://localhost:6379

POSTGRES_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable
REDIS_URL=redis://localhost:6379

# Optional tuning (these have safe defaults in the binary)
# TABLE_OUTBOX=outbox
# TABLE_CONFIG=relay_config
# BATCH_SIZE=500
# POLL_INTERVAL=10
# RETENTION_DAYS=7